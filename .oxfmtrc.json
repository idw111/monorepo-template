{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "tabWidth": 2,
  "trailingComma": "es5",
  "semi": true,
  "singleQuote": true,
  "printWidth": 160,
  "sortImports": {
    "newlinesBetween": false
  },
  "ignorePatterns": ["**/.next/**", "**/dist/**", "**/coverage/**", "**/node_modules/**"]
}
